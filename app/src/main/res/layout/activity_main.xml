<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_heading"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <!-- Interstitial button -->
        <Button
            android:id="@+id/btnShowInterstitial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/show_interstitial"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

        <!-- Native Small label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_native_small"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#999999"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:paddingHorizontal="16dp"
            android:paddingBottom="4dp" />

        <!-- Native Ad (Small) -->
        <com.elytelabs.ads.ui.NativeAdView
            android:id="@+id/nativeAdView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Native Medium label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_native_medium"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#999999"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <!-- Native Ad (Medium) -->
        <com.elytelabs.ads.ui.NativeAdMediumView
            android:id="@+id/nativeAdMediumView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Spacer to push banner down -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Banner label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_banner"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#999999"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:paddingHorizontal="16dp"
            android:paddingBottom="4dp" />

        <!-- Banner Ad -->
        <com.elytelabs.ads.ui.BannerAdView
            android:id="@+id/bannerAdView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</ScrollView>
